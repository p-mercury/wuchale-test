{
	"name": "@wuchale-test/library",
	"private": true,
	"type": "module",
	"exports": {
		"./package.json": "./package.json",
		"./*": "./dist/lib/*",
		"./enum/*": {
			"types": "./dist/lib/enum/*.d.ts",
			"default": "./dist/lib/enum/*"
		}
	},
	"main": "./dist/lib/index.js",
	"types": "./dist/lib/index.d.ts",
	"scripts": {
		"build": "vite build && npm run prepack",
		"lint": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"lint:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"prepack": "svelte-kit sync && svelte-package -o dist/lib",
		"start": "vite dev"
	},
	"dependencies": {
		"@svelte-put/inline-svg": "^4.0.2",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.58.0",
		"@sveltejs/package": "^2.5.7",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"sass": "^1.99.0",
		"svelte": "^5.55.5",
		"svelte-check": "^4.4.6",
		"typescript": "^6.0.3",
		"vite": "^8.0.10"
	}
}
