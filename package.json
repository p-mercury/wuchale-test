{
	"name": "wuchale-test",
	"private": true,
	"workspaces": [
		"./library",
		"./site"
	],
	"scripts": {
		"build": "turbo build",
		"clean": "find . -name 'node_modules' -type d -prune -exec rm -rf '{}' + && find . -name 'dist' -type d -prune -exec rm -rf '{}' + && find . -name 'package-lock.json' -type f -prune -exec rm -f '{}' +",
		"forcebuild": "turbo build --force",
		"forcegenerate": "turbo run generate --force",
		"generate": "turbo run generate",
		"lint": "turbo lint"
	},
	"prettier": {
		"plugins": [
			"prettier-plugin-packagejson",
			"prettier-plugin-svelte"
		],
		"useTabs": true,
		"overrides": [
			{
				"files": "*.svelte",
				"options": {
					"parser": "svelte"
				}
			}
		]
	},
	"overrides": {
		"cookie": "^1.1.1",
		"glob": "^13.0.6",
		"minimatch": "^10.2.4"
	},
	"devDependencies": {
		"prettier": "^3.8.1",
		"prettier-plugin-packagejson": "^3.0.2",
		"prettier-plugin-svelte": "^3.5.1",
		"turbo": "^2.8.20",
		"typescript-svelte-plugin": "^0.3.50"
	},
	"packageManager": "npm@11.12.1"
}
